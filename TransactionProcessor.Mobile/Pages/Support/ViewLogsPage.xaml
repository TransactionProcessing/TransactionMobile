<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.Support.ViewLogsPage"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="auto,*,auto" BackgroundColor="{StaticResource pageBackgroundColor}">

        <!-- Header -->
        <Frame Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}" AutomationId="ViewLogs"/>
        </Frame>

        <!-- Log messages list -->
        <ListView Grid.Row="1" ItemsSource="{Binding LogMessages}"
                  HasUnevenRows="True" VerticalScrollBarVisibility="Always"
                  Margin="16,8">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <VerticalStackLayout Padding="8,6" Spacing="2">
                            <Label Text="{Binding Path=EntryDateTime, StringFormat='{0:dd/MM/yyyy HH:mm:ss}'}"
                                   FontAttributes="Bold" FontSize="12"
                                   TextColor="{Binding TextColor}"/>
                            <Label Text="{Binding LogLevel}" FontSize="11"
                                   TextColor="{Binding TextColor}"/>
                            <Label Text="{Binding Message}" LineBreakMode="WordWrap" FontSize="12"
                                   TextColor="{Binding TextColor}"/>
                        </VerticalStackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Back tile -->
        <Frame Grid.Row="2" Style="{StaticResource ActionTileStyle}"
               BackgroundColor="{StaticResource MidGray}"
               AutomationId="BackButton" Margin="16,8">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding BackButtonCommand}"/>
            </Frame.GestureRecognizers>
            <Label Text="Back" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
        </Frame>

    </Grid>
</ContentPage>
