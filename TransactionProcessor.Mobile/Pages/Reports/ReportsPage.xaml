<?xml version="1.0" encoding="utf-8" ?>
<common:NoBackWithoutLogoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                               xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
                               xmlns:common="clr-namespace:TransactionProcessor.Mobile.Pages.Common"
                               x:Class="TransactionProcessor.Mobile.Pages.Reports.ReportsPage"
                               Shell.NavBarIsVisible="False">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}" AutomationId="{Binding Title}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"/>
            </Frame>

            <!-- Reports grid (dynamically populated) -->
            <VerticalStackLayout Padding="16,16,16,16" Spacing="10">
                <Grid x:Name="ReportsList" ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</common:NoBackWithoutLogoutPage>
