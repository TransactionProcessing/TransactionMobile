<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.Reports.ReportsSalesAnalysisPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:reports1="clr-namespace:TransactionProcessor.Mobile.BusinessLogic.ViewModels.Reports;assembly=TransactionProcessor.Mobile.BusinessLogic"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             Shell.NavBarIsVisible="False"
             x:Name="SalesAnalysisPage">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:SelectedItemEventArgsConverter x:Key="SelectedItemEventArgsConverter"/>
        </ResourceDictionary>

        <DataTemplate x:Key="CardTemplate">
            <Frame CornerRadius="16" HasShadow="True" Padding="0" Margin="0,0,0,8"
                   BorderColor="Transparent"
                   x:DataType="reports1:SalesAnalysis"
                   BackgroundColor="{StaticResource cardBackgroundColor}">
                <Grid RowDefinitions="auto,auto,auto" Padding="16,12">

                    <!-- Title row with icon -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,auto">
                        <Label Grid.Column="0" Text="{Binding MainTitle}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}"/>
                        <Image Grid.Column="1" Source="{Binding Icon}"
                               WidthRequest="32" HeightRequest="32"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Today's value -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,auto" Margin="0,8,0,0">
                        <Label Grid.Column="0" Text="{Binding TodaysTitle}"
                               FontSize="12" TextColor="{StaticResource MidGray}"/>
                        <Label Grid.Column="1" Text="{Binding TodaysValue}"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}"/>
                    </Grid>

                    <!-- Comparison and variance -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,auto,auto,auto" Margin="0,4,0,0">
                        <Label Grid.Column="0" Text="{Binding ComparisonTitle}"
                               FontSize="12" TextColor="{StaticResource MidGray}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding ComparisonValue}"
                               FontSize="13" TextColor="{StaticResource DarkGray}"
                               VerticalOptions="Center" Margin="0,0,12,0"/>
                        <Label Grid.Column="2" Text="{Binding VarianceTitle}"
                               FontSize="12" TextColor="{StaticResource MidGray}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="3" Text="{Binding VarianceValue}"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource successGreen}"
                               VerticalOptions="Center" Margin="4,0,0,0"/>
                    </Grid>

                </Grid>
            </Frame>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid RowDefinitions="auto,auto,*,auto" BackgroundColor="{StaticResource pageBackgroundColor}">

        <!-- Header -->
        <Frame Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}" AutomationId="SalesAnalysis"/>
        </Frame>

        <!-- Date picker -->
        <Frame Grid.Row="1" Style="{StaticResource SectionCardStyle}" Margin="16,12,16,0">
            <Picker x:Name="ComparisonDate"
                    Title="Select Date for Comparison"
                    ItemDisplayBinding="{Binding DisplayText}"
                    ItemsSource="{Binding ComparisonDates}"
                    SelectedItem="{Binding SelectedItem}"
                    TextColor="{StaticResource labelTextColor}">
                <Picker.Behaviors>
                    <toolkit:EventToCommandBehavior
                        EventName="SelectedIndexChanged"
                        Command="{Binding ComparisonDatePickerSelectedIndexChangedCommand}"
                        BindingContext="{Binding Source={x:Reference SalesAnalysisPage}, Path=BindingContext}"/>
                </Picker.Behaviors>
            </Picker>
        </Frame>

        <!-- Sales analysis list -->
        <CollectionView Grid.Row="2"
                        Margin="16,8,16,0"
                        ItemsSource="{Binding SalesAnalysisList}"
                        ItemTemplate="{StaticResource CardTemplate}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="1"
                                 VerticalItemSpacing="0"
                                 HorizontalItemSpacing="0"/>
            </CollectionView.ItemsLayout>
        </CollectionView>

        <!-- Back tile -->
        <Frame Grid.Row="3" Style="{StaticResource ActionTileStyle}"
               BackgroundColor="{StaticResource MidGray}"
               AutomationId="BackButton" Margin="16,8">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding BackButtonCommand}"/>
            </Frame.GestureRecognizers>
            <Label Text="Back" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
        </Frame>

    </Grid>
</ContentPage>
