<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.MyAccount.MyAccountContactPage"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             Shell.NavBarIsVisible="False">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"
                       AutomationId="{Binding Title}"/>
            </Frame>

            <VerticalStackLayout Padding="16,16,16,16" Spacing="12">

                <!-- Primary Contact card -->
                <Frame Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout x:Name="SubLayout" Spacing="0">

                        <Label Text="Primary Contact" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}" Margin="0,0,0,12"
                               AutomationId="PrimaryContactLabel"/>

                        <!-- Name -->
                        <Label Text="Name" FontSize="12" TextColor="{StaticResource MidGray}"/>
                        <Label Text="{Binding Contact.Name}" FontSize="15"
                               FontAttributes="Bold" TextColor="{StaticResource labelTextColor}"
                               Margin="0,0,0,12" AutomationId="ContactNameLabel"/>

                        <!-- Email -->
                        <Label Text="Email Address" FontSize="12" TextColor="{StaticResource MidGray}"/>
                        <Label Text="{Binding Contact.EmailAddress}" FontSize="15"
                               FontAttributes="Bold" TextColor="{StaticResource labelTextColor}"
                               Margin="0,0,0,12" AutomationId="ContactEmailAddressLabel"/>

                        <!-- Mobile -->
                        <Label Text="Mobile Number" FontSize="12" TextColor="{StaticResource MidGray}"/>
                        <Label Text="{Binding Contact.MobileNumber}" FontSize="15"
                               FontAttributes="Bold" TextColor="{StaticResource labelTextColor}"
                               AutomationId="ContactMobileNumberLabel"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- Action tiles row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Frame Grid.Column="0" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource profile}"
                           AutomationId="EditContactButton">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer/>
                        </Frame.GestureRecognizers>
                        <Label Text="Edit Contact" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>

                    <Frame Grid.Column="1" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource MidGray}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackButtonCommand}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="Back" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
