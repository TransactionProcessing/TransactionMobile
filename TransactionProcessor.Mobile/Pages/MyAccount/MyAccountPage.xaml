<?xml version="1.0" encoding="utf-8" ?>
<common:NoBackWithoutLogoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                               x:Class="TransactionProcessor.Mobile.Pages.MyAccount.MyAccountPage"
                               xmlns:common="clr-namespace:TransactionProcessor.Mobile.Pages.Common"
                               xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
                               Shell.NavBarIsVisible="False">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header section -->
            <Frame Style="{StaticResource PageHeaderStyle}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"
                           AutomationId="{Binding Title}"/>
                    <Label Text="{Binding MerchantName}" Style="{StaticResource HeaderSubtitleStyle}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Account info section -->
            <VerticalStackLayout Padding="16,16,16,16" Spacing="0">

                <!-- Last login card -->
                <Frame Style="{StaticResource SectionCardStyle}">
                    <Grid ColumnDefinitions="*,auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Last Login" FontSize="12" TextColor="{StaticResource MidGray}"/>
                            <Label Text="{Binding LastLogin, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource labelTextColor}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Options grid (dynamically populated) -->
                <Grid x:Name="MyAccountOptionsList" ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10"/>

                <Frame Style="{StaticResource ActionTileStyle}"
                       BackgroundColor="{StaticResource MidGray}"
                       AutomationId="BackButton" Margin="0,8,0,0">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackButtonCommand}"/>
                    </Frame.GestureRecognizers>
                    <Label Text="Back" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                </Frame>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</common:NoBackWithoutLogoutPage>
