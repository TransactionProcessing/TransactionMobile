<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.MyAccount.MyAccountAddressesPage"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             Shell.NavBarIsVisible="False">
    <ScrollView AutomationId="MyAddresses" BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"/>
            </Frame>

            <VerticalStackLayout Padding="16,16,16,16" Spacing="12">

                <!-- Primary Address card -->
                <Frame Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout x:Name="SubLayout" Spacing="6">

                        <Label Text="Primary Address" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}" Margin="0,0,0,8"
                               AutomationId="PrimaryAddressLabel"/>

                        <Label Text="{Binding Address.AddressLine1}"
                               TextColor="{StaticResource DarkGray}" FontSize="14"
                               AutomationId="AddressLine1Label"/>
                        <Label Text="{Binding Address.AddressLine2}" x:Name="AddressLine2"
                               TextColor="{StaticResource DarkGray}" FontSize="14"
                               AutomationId="AddressLine2Label"/>
                        <Label Text="{Binding Address.AddressLine3}" x:Name="AddressLine3"
                               TextColor="{StaticResource DarkGray}" FontSize="14"
                               AutomationId="AddressLine3Label"/>
                        <Label Text="{Binding Address.AddressLine4}" x:Name="AddressLine4"
                               TextColor="{StaticResource DarkGray}" FontSize="14"
                               AutomationId="AddressLine4Label"/>

                        <!-- Town / Region / PostCode row -->
                        <Grid ColumnDefinitions="*,*,auto" Margin="0,4,0,0">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Town" FontSize="11" TextColor="{StaticResource MidGray}"/>
                                <Label Text="{Binding Address.Town}" FontSize="14"
                                       FontAttributes="Bold" TextColor="{StaticResource labelTextColor}"
                                       AutomationId="AddressTownLabel"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Region" FontSize="11" TextColor="{StaticResource MidGray}"/>
                                <Label Text="{Binding Address.Region}" FontSize="14"
                                       FontAttributes="Bold" TextColor="{StaticResource labelTextColor}"
                                       AutomationId="AddressRegionLabel"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="2">
                                <Label Text="Post Code" FontSize="11" TextColor="{StaticResource MidGray}"/>
                                <Label Text="{Binding Address.PostalCode}" FontSize="14"
                                       FontAttributes="Bold" TextColor="{StaticResource labelTextColor}"
                                       AutomationId="AddressPostCodeLabel"/>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <!-- Action tiles row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Frame Grid.Column="0" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource profile}"
                           AutomationId="EditAddressButton">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer/>
                        </Frame.GestureRecognizers>
                        <Label Text="Edit Address" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>

                    <Frame Grid.Column="1" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource MidGray}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackButtonCommand}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="Back" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
