<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.MyAccount.MyAccountDetailsPage"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             Shell.NavBarIsVisible="False">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"
                       AutomationId="{Binding Title}"/>
            </Frame>

            <VerticalStackLayout Padding="16,16,16,16" Spacing="12">

                <!-- Merchant info card -->
                <Frame Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Merchant" FontSize="13" TextColor="{StaticResource MidGray}"/>
                        <Label Text="{Binding MerchantName}" FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}"
                               AutomationId="MerchantNameLabel"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Balance card -->
                <Frame Style="{StaticResource BalanceCardStyle}">
                    <Grid ColumnDefinitions="*,*">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Balance" TextColor="White" FontSize="13" Opacity="0.85"/>
                            <Label Text="{Binding Balance}" TextColor="White"
                                   FontSize="22" FontAttributes="Bold"
                                   AutomationId="BalanceLabel"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Available" TextColor="White" FontSize="13" Opacity="0.85"/>
                            <Label Text="{Binding AvailableBalance}" TextColor="White"
                                   FontSize="22" FontAttributes="Bold"
                                   AutomationId="AvailableBalanceLabel"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Statement info -->
                <Frame Style="{StaticResource SectionCardStyle}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="auto,auto,auto">
                        <Label Grid.Row="0" Grid.Column="0" Text="Last Statement"
                               FontSize="12" TextColor="{StaticResource MidGray}"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="{Binding LastStatementDate, StringFormat='{0:dd/MM/yyyy}'}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}"
                               AutomationId="LastStatementDateLabel"/>

                        <Label Grid.Row="0" Grid.Column="1" Text="Next Statement"
                               FontSize="12" TextColor="{StaticResource MidGray}"/>
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding NextStatementDate, StringFormat='{0:dd/MM/yyyy}'}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}"
                               AutomationId="NextStatementDateLabel"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="Settlement Schedule"
                               FontSize="12" TextColor="{StaticResource MidGray}" Margin="0,8,0,0"/>
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding SettlementSchedule}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}" Margin="0,8,0,0"
                               AutomationId="SettlementScheduleLabel"/>
                    </Grid>
                </Frame>

                <Button Text="Back" AutomationId="BackButton"
                        Style="{StaticResource MyAccountButtonStyle}"
                        Command="{Binding BackButtonCommand}"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
