<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.Transactions.BillPayment.BillPaymentGetAccountPage"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             Shell.NavBarIsVisible="False"
             x:Name="BillPaymentGetAccount">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}" AutomationId="GetCustomerAccount"/>
            </Frame>

            <VerticalStackLayout Padding="16,16,16,16" Spacing="12">

                <Frame Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Account Number" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="CustomerAccountNumberEntry"
                                   Placeholder="Customer Account Number"
                                   AutomationId="CustomerAccountNumberEntry"
                                   Style="{DynamicResource CustomerAccountNumberEntryStyle}"
                                   Text="{Binding CustomerAccountNumber}"
                                   Keyboard="Numeric"/>
                        </Frame>

                    </VerticalStackLayout>
                </Frame>

                <!-- Action tiles row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Frame Grid.Column="0" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource billPayment}"
                           AutomationId="GetAccountButton">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GetAccountCommand}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="Get Account" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>

                    <Frame Grid.Column="1" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource MidGray}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackButtonCommand}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="Back" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
