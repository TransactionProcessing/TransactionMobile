<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="TransactionProcessor.Mobile.Pages.Transactions.BillPayment.BillPaymentSuccessPage"
             Shell.NavBarIsVisible="False"
             x:Name="BillPaymentSuccess">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}" BackgroundColor="{StaticResource successGreen}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"
                       AutomationId="{Binding Title}"/>
            </Frame>

            <VerticalStackLayout Padding="16,24,16,16" Spacing="16">

                <Frame Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Image Source="paymentsuccess.png" VerticalOptions="Start"
                               HeightRequest="120" WidthRequest="120"
                               HorizontalOptions="Center"/>
                        <Label Text="Payment Successful!"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource successGreen}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Thank you for your bill payment. An automated payment receipt will be sent to your email address."
                               FontSize="14" TextColor="{StaticResource DarkGray}"
                               HorizontalTextAlignment="Center"
                               Margin="8,0"/>
                    </VerticalStackLayout>
                </Frame>

                <Button x:Name="CompleteButton" Text="Complete"
                        Style="{DynamicResource BillPaymentButtonStyle}"
                        AutomationId="CompleteButton">
                    <Button.Behaviors>
                        <toolkit:EventToCommandBehavior
                            EventName="Clicked"
                            Command="{Binding CompletedCommand}"
                            BindingContext="{Binding Source={x:Reference BillPaymentSuccess}, Path=BindingContext}"/>
                    </Button.Behaviors>
                </Button>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
