<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="TransactionProcessor.Mobile.Pages.Transactions.BillPayment.BillPaymentGetMeterPage"
             Shell.NavBarIsVisible="False"
             x:Name="BillPaymentGetMeter">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"
                       AutomationId="{Binding Title}"/>
            </Frame>

            <VerticalStackLayout Padding="16,16,16,16" Spacing="12">

                <Frame Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Meter Number" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="MeterNumberEntry"
                                   Placeholder="Meter Number"
                                   AutomationId="MeterNumberEntry"
                                   Style="{DynamicResource CustomerAccountNumberEntryStyle}"
                                   Text="{Binding MeterNumber}"
                                   Keyboard="Numeric"/>
                        </Frame>

                    </VerticalStackLayout>
                </Frame>

                <Button x:Name="GetMeterButton" Text="Get Meter"
                        Style="{DynamicResource BillPaymentButtonStyle}"
                        AutomationId="GetMeterButton">
                    <Button.Behaviors>
                        <toolkit:EventToCommandBehavior
                            EventName="Clicked"
                            Command="{Binding GetMeterCommand}"
                            BindingContext="{Binding Source={x:Reference BillPaymentGetMeter}, Path=BindingContext}"/>
                    </Button.Behaviors>
                </Button>

                <Button Text="Back" Style="{StaticResource BillPaymentButtonStyle}"
                        Command="{Binding BackButtonCommand}"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
