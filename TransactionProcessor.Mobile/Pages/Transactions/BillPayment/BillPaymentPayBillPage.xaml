<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.Transactions.BillPayment.BillPaymentPayBillPage"
             xmlns:behaviors="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             Shell.NavBarIsVisible="False"
             x:Name="BillPaymentPayBill">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}" AutomationId="{Binding Title}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"/>
            </Frame>

            <VerticalStackLayout Padding="16,16,16,16" Spacing="12">

                <!-- Post Pay section -->
                <Frame Style="{StaticResource SectionCardStyle}" IsVisible="{Binding IsPostPayVisible}">
                    <VerticalStackLayout x:Name="PostPayLayout" Spacing="8">
                        <Label Text="Bill Details" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}" Margin="0,0,0,8"
                               AutomationId="PrimaryAddressLabel"/>

                        <Label Text="{Binding BillDetails.AccountNumber, StringFormat='Account Number: {0}'}"
                               TextColor="{StaticResource DarkGray}" AutomationId="AccountNumber"/>
                        <Label Text="{Binding BillDetails.AccountName, StringFormat='Account Holder: {0}'}"
                               TextColor="{StaticResource DarkGray}" AutomationId="AccountName"/>
                        <Label Text="{Binding BillDetails.Balance, StringFormat='Balance: {0} KES'}"
                               TextColor="{StaticResource DarkGray}" AutomationId="Balance"/>
                        <Label Text="{Binding BillDetails.DueDate, StringFormat='Due Date: {0}'}"
                               TextColor="{StaticResource DarkGray}" AutomationId="DueDate"/>

                        <Label Text="Mobile Number" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold" Margin="0,8,0,0"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="CustomerMobileNumberEntry"
                                   Placeholder="Customer Mobile Number"
                                   AutomationId="CustomerMobileNumberEntry"
                                   Style="{DynamicResource CustomerMobileNumberEntryStyle}"
                                   Text="{Binding CustomerMobileNumber}"
                                   Keyboard="Numeric">
                                <Entry.Behaviors>
                                    <behaviors:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding CustomerMobileNumberEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>

                        <Label Text="Payment Amount" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="PostPaymentAmountEntry"
                                   Placeholder="100"
                                   AutomationId="PostPaymentAmountEntry"
                                   Style="{DynamicResource AmountEntryStyle}"
                                   Text="{Binding PaymentAmount}"
                                   Keyboard="Numeric">
                                <Entry.Behaviors>
                                    <behaviors:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding PaymentAmountEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Pre Pay section -->
                <Frame Style="{StaticResource SectionCardStyle}" IsVisible="{Binding IsPrePayVisible}">
                    <VerticalStackLayout x:Name="PrePayLayout" Spacing="8">
                        <Label Text="Meter Details" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource labelTextColor}" Margin="0,0,0,8"
                               AutomationId="PrimaryAddressLabel"/>

                        <Label Text="{Binding MeterDetails.MeterNumber, StringFormat='Meter Number: {0}'}"
                               TextColor="{StaticResource DarkGray}" AutomationId="MeterNumber"/>

                        <Label Text="Payment Amount" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold" Margin="0,8,0,0"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="PrePaymentAmountEntry"
                                   Placeholder="100"
                                   AutomationId="PrePaymentAmountEntry"
                                   Style="{DynamicResource AmountEntryStyle}"
                                   Text="{Binding PaymentAmount}"
                                   Keyboard="Numeric">
                                <Entry.Behaviors>
                                    <behaviors:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding PaymentAmountEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Action tiles row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Frame Grid.Column="0" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource billPayment}"
                           AutomationId="MakePaymentButton">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding MakeBillPaymentCommand}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="Make Payment" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>

                    <Frame Grid.Column="1" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource MidGray}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackButtonCommand}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="Back" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
