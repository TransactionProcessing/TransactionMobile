<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.Transactions.BillPayment.BillPaymentPayBillPage"
             xmlns:behaviors="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
             Shell.NavBarIsVisible="False"
             Padding="0"
             x:Name="BillPaymentPayBill">
    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header with gradient background -->
            <Grid HeightRequest="130">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource billPayment}" Offset="0.0"/>
                        <GradientStop Color="#2b8ccc" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="4" Padding="20">
                    <Label Text="{Binding Title}"
                           AutomationId="{Binding Title}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label Text="Review details and make payment"
                           FontSize="13"
                           TextColor="White"
                           Opacity="0.85"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Content -->
            <VerticalStackLayout Padding="20,20,20,16" Spacing="12">

                <Frame Style="{StaticResource TransactionFormCard}" IsVisible="{Binding IsPostPayVisible}">
                    <VerticalStackLayout x:Name="PostPayLayout" Spacing="10">
                        <Label Text="Bill Details"
                               HorizontalTextAlignment="Center"
                               HorizontalOptions="Fill"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{StaticResource labelTextColor}"
                               Margin="0,0,0,8"
                               AutomationId="PrimaryAddressLabel"/>

                        <Label Text="{Binding BillDetails.AccountNumber, StringFormat='Account Number: {0}'}"
                               HorizontalTextAlignment="Start"
                               HorizontalOptions="Fill" AutomationId="AccountNumber"/>
                        <Label Text="{Binding BillDetails.AccountName, StringFormat='Account Holder: {0}'}"
                               HorizontalTextAlignment="Start"
                               HorizontalOptions="Fill" AutomationId="AccountName"/>
                        <Label Text="{Binding BillDetails.Balance, StringFormat='Balance: {0} KES'}"
                               HorizontalTextAlignment="Start"
                               HorizontalOptions="Fill" AutomationId="Balance"/>
                        <Label Text="{Binding BillDetails.DueDate, StringFormat='Due Date: {0}'}"
                               HorizontalTextAlignment="Start"
                               HorizontalOptions="Fill" AutomationId="DueDate"/>

                        <Entry x:Name="CustomerMobileNumberEntry"
                               Placeholder="Customer Mobile Number"
                               AutomationId="CustomerMobileNumberEntry"
                               Style="{DynamicResource CustomerMobileNumberEntryStyle}"
                               Text="{Binding CustomerMobileNumber}"
                               Keyboard="Numeric">
                            <Entry.Behaviors>
                                <behaviors:EventToCommandBehavior
                                    EventName="Completed"
                                    Command="{Binding CustomerMobileNumberEntryCompletedCommand}" />
                            </Entry.Behaviors>
                        </Entry>

                        <Entry x:Name="PostPaymentAmountEntry"
                               Placeholder="100"
                               AutomationId="PostPaymentAmountEntry"
                               Style="{DynamicResource AmountEntryStyle}"
                               Text="{Binding PaymentAmount}"
                               Keyboard="Numeric">
                            <Entry.Behaviors>
                                <behaviors:EventToCommandBehavior
                                    EventName="Completed"
                                    Command="{Binding PaymentAmountEntryCompletedCommand}" />
                            </Entry.Behaviors>
                        </Entry>
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource TransactionFormCard}" IsVisible="{Binding IsPrePayVisible}">
                    <VerticalStackLayout x:Name="PrePayLayout" Spacing="10">
                        <Label Text="Meter Details"
                               HorizontalTextAlignment="Center"
                               HorizontalOptions="Fill"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="{StaticResource labelTextColor}"
                               Margin="0,0,0,8"
                               AutomationId="PrimaryAddressLabel"/>

                        <Label Text="{Binding MeterDetails.MeterNumber, StringFormat='Meter Number: {0}'}"
                               HorizontalTextAlignment="Start"
                               HorizontalOptions="Fill" AutomationId="MeterNumber"/>

                        <Entry x:Name="PrePaymentAmountEntry"
                               Placeholder="100"
                               AutomationId="PrePaymentAmountEntry"
                               Style="{DynamicResource AmountEntryStyle}"
                               Text="{Binding PaymentAmount}"
                               Keyboard="Numeric">
                            <Entry.Behaviors>
                                <behaviors:EventToCommandBehavior
                                    EventName="Completed"
                                    Command="{Binding PaymentAmountEntryCompletedCommand}" />
                            </Entry.Behaviors>
                        </Entry>
                    </VerticalStackLayout>
                </Frame>

                <Button x:Name="MakePaymentButton" Text="Make Payment"
                        Style="{DynamicResource BillPaymentButtonStyle}" AutomationId="MakePaymentButton">
                    <Button.Behaviors>
                        <behaviors:EventToCommandBehavior
                            EventName="Clicked"
                            Command="{Binding MakeBillPaymentCommand}" BindingContext="{Binding Source={x:Reference BillPaymentPayBill}, Path=BindingContext}" />
                    </Button.Behaviors>
                </Button>
                <Button Text="Back" Style="{StaticResource StandardButton}" Command="{Binding BackButtonCommand}"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>