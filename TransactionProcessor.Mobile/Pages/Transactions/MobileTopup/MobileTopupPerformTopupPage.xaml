<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.Transactions.MobileTopup.MobileTopupPerformTopupPage"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             Shell.NavBarIsVisible="False"
             x:Name="MobileTopPerformTopup">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"
                       AutomationId="{Binding Title}"/>
            </Frame>

            <VerticalStackLayout Padding="16,16,16,16" Spacing="12">

                <Frame Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Customer Mobile Number" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="CustomerMobileNumberEntry"
                                   Placeholder="Customer Mobile Number"
                                   Style="{DynamicResource MobileNumberEntryStyle}"
                                   AutomationId="CustomerMobileNumberEntry"
                                   Text="{Binding CustomerMobileNumber}"
                                   Keyboard="Numeric">
                                <Entry.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding CustomerMobileNumberEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>

                        <Label Text="Topup Amount" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="TopupAmountEntry"
                                   Placeholder="100"
                                   AutomationId="TopupAmountEntry"
                                   Style="{DynamicResource AmountEntryStyle}"
                                   Text="{Binding TopupAmount}"
                                   Keyboard="Numeric">
                                <Entry.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding TopupAmountEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>

                        <Label Text="Customer Email (optional)" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="CustomerEmailAddressEntry"
                                   Placeholder="customer@email.com"
                                   AutomationId="CustomerEmailAddressEntry"
                                   Style="{DynamicResource EmailAddressEntryStyle}"
                                   Text="{Binding CustomerEmailAddress}">
                                <Entry.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding CustomerEmailAddressEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>

                    </VerticalStackLayout>
                </Frame>

                <Button x:Name="PerformTopupButton" Text="Perform Topup"
                        Style="{DynamicResource MobileTopupButtonStyle}"
                        AutomationId="PerformTopupButton">
                    <Button.Behaviors>
                        <toolkit:EventToCommandBehavior
                            EventName="Clicked"
                            Command="{Binding PerformTopupCommand}"
                            BindingContext="{Binding Source={x:Reference MobileTopPerformTopup}, Path=BindingContext}"/>
                    </Button.Behaviors>
                </Button>

                <Button Text="Back" Style="{StaticResource MobileTopupButtonStyle}"
                        Command="{Binding BackButtonCommand}"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
