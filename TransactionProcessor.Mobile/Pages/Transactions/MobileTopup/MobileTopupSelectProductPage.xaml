<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             x:Class="TransactionProcessor.Mobile.Pages.Transactions.MobileTopup.MobileTopupSelectProductPage"
             Shell.NavBarIsVisible="False">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}"
                       AutomationId="{Binding Title}"/>
            </Frame>

            <VerticalStackLayout Padding="16,16,16,16" Spacing="10">
                <VerticalStackLayout x:Name="ProductsList" Spacing="10"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
