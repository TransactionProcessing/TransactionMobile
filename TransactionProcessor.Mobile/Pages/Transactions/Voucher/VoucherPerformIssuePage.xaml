<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransactionProcessor.Mobile.Pages.Transactions.Voucher.VoucherPerformIssuePage"
             xmlns:controls="clr-namespace:TransactionProcessor.Mobile.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             Shell.NavBarIsVisible="False"
             x:Name="VoucherPerformIssue">
    <ScrollView BackgroundColor="{StaticResource pageBackgroundColor}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Frame Style="{StaticResource PageHeaderStyle}">
                <Label Text="{Binding Title}" Style="{StaticResource HeaderTitleStyle}" AutomationId="EnterVoucherIssueDetails"/>
            </Frame>

            <VerticalStackLayout Padding="16,16,16,16" Spacing="12">

                <Frame Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Recipient Mobile Number" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="RecipientMobileNumberEntry"
                                   Placeholder="Recipient Mobile Number"
                                   AutomationId="RecipientMobileNumberEntry"
                                   Style="{DynamicResource MobileNumberEntryStyle}"
                                   Text="{Binding RecipientMobileNumber}"
                                   Keyboard="Numeric">
                                <Entry.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding RecipientMobileNumberEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>

                        <Label Text="Recipient Email Address" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="RecipientEmailAddressEntry"
                                   Placeholder="Recipient Email Address"
                                   AutomationId="RecipientEmailAddressEntry"
                                   Style="{DynamicResource EmailAddressEntryStyle}"
                                   Text="{Binding RecipientEmailAddress}">
                                <Entry.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding RecipientEmailAddressEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>

                        <Label Text="Voucher Amount" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="VoucherAmountEntry"
                                   Placeholder="100"
                                   AutomationId="VoucherAmountEntry"
                                   Style="{DynamicResource AmountEntryStyle}"
                                   Text="{Binding VoucherAmount}"
                                   Keyboard="Numeric">
                                <Entry.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding VoucherAmountEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>

                        <Label Text="Customer Email (optional)" FontSize="13"
                               TextColor="{StaticResource labelTextColor}" FontAttributes="Bold"/>
                        <Frame Style="{StaticResource FormEntryStyle}">
                            <Entry x:Name="CustomerEmailAddressEntry"
                                   Placeholder="customer@email.com"
                                   AutomationId="CustomerEmailAddressEntry"
                                   Style="{DynamicResource EmailAddressEntryStyle}"
                                   Text="{Binding CustomerEmailAddress}">
                                <Entry.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                        EventName="Completed"
                                        Command="{Binding CustomerEmailAddressEntryCompletedCommand}"/>
                                </Entry.Behaviors>
                            </Entry>
                        </Frame>

                    </VerticalStackLayout>
                </Frame>

                <!-- Action tiles row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Frame Grid.Column="0" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource voucher}"
                           AutomationId="IssueVoucherButton">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IssueVoucherCommand}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="Issue Voucher" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>

                    <Frame Grid.Column="1" Style="{StaticResource ActionTileStyle}"
                           BackgroundColor="{StaticResource MidGray}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackButtonCommand}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="Back" Style="{StaticResource TileLabelStyle}" FontAttributes="Bold"/>
                    </Frame>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
